{
  "info": {
    "name": "PrintMixBox API",
    "description": "IoT Printing & Box Branding Platform — Auth Module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token",    "value": "", "type": "string" },
    { "key": "company_code", "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Health Check",
      "request": {
        "method": "GET",
        "url": "http://localhost:5000/health"
      }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "1. Register Company",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('company_code', res.data.companyCode);",
                  "  console.log('Company Code:', res.data.companyCode);",
                  "  if (res.debug) console.log('OTP (dev):', res.debug.verificationCode);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyName\": \"Acme Packaging Pvt Ltd\",\n  \"gstNumber\": \"27AAPFU0939F1ZV\",\n  \"email\": \"test@acme.com\",\n  \"username\": \"acme_admin\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "2. Verify Email",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyCode\": \"{{company_code}}\",\n  \"verificationCode\": \"PASTE_OTP_HERE\"\n}"
            }
          }
        },
        {
          "name": "3. Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.success) {",
                  "  pm.collectionVariables.set('token', res.data.token);",
                  "  console.log('JWT Token saved.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyCode\": \"{{company_code}}\",\n  \"username\": \"acme_admin\",\n  \"password\": \"Test@1234\"\n}"
            }
          }
        },
        {
          "name": "4. Get Profile (Protected)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base_url}}/auth/me"
          }
        },
        {
          "name": "5. Resend Verification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/auth/resend-verification",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"companyCode\": \"{{company_code}}\"\n}"
            }
          }
        }
      ]
    }
  ]
}
